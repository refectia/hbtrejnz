function ClearAllTags()
    if RenderConnection then
        RenderConnection:Disconnect()
        RenderConnection = nil
    end

    local function SafeDestroy(t)
        for i, v in pairs(t) do
            pcall(function()
                if typeof(v) == "Instance" then v:Destroy() end
            end)
        end
        table.clear(t)
    end

    SafeDestroy(CorpseTags)
    SafeDestroy(ContainerTags)
    SafeDestroy(ItemTags)
    SafeDestroy(TraderTags)

    for _, p in ipairs(Players:GetPlayers()) do
        pcall(function()
            if p.Character then
                local targets = {p.Character, p.Character:FindFirstChild("Head")}
                for _, parent in pairs(targets) do
                    if parent then
                        for _, obj in ipairs(parent:GetChildren()) do
                            if obj.Name == "SOA_ESPTag" or obj.Name == "SOA_Highlight" or obj.Name == "SOA_ViewConePart" then
                                obj:Destroy()
                            end
                        end
                    end
                end
                if p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.Transparency = 1
                end
            end
        end)
    end
end

