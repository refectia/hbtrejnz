getgenv().KeybindConnection = UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if not getgenv().Keybinds or not getgenv().Keybinds.EnableKeybinds then return end

    local pressed = input.KeyCode

    if pressed == getgenv().Keybinds.Fly then
        getgenv().Movement_Settings.FlightEnabled = not getgenv().Movement_Settings.FlightEnabled

    elseif pressed == getgenv().Keybinds.Noclip then
        getgenv().Movement_Settings.NoClipEnabled = not getgenv().Movement_Settings.NoClipEnabled

    elseif pressed == getgenv().Keybinds.SilentAim then
        getgenv().Weapon_Settings.MagicBullet = not getgenv().Weapon_Settings.MagicBullet

    elseif pressed == getgenv().Keybinds.Hitbox then
        getgenv().Hitbox_Settings.Enabled = not getgenv().Hitbox_Settings.Enabled
        if not getgenv().Hitbox_Settings.Enabled then
            pcall(ClearAllTags)
        end

    elseif pressed == getgenv().Keybinds.Renamer then
        getgenv().Weapon_Settings.SpoofEnabled = not getgenv().Weapon_Settings.SpoofEnabled

    elseif pressed == getgenv().Keybinds.AmmoEditor then
        getgenv().DropMod_Settings.Enabled = not getgenv().DropMod_Settings.Enabled

    elseif pressed == getgenv().Keybinds.WeaponMods then
        local nr = getgenv().Weapon_Settings.NoRecoil
        getgenv().Weapon_Settings.NoRecoil = not nr
        getgenv().Weapon_Settings.RapidFire = not nr

    elseif pressed == getgenv().Keybinds.Duplicator then
        getgenv().DropValueEnabled = not getgenv().DropValueEnabled
    end
end)

