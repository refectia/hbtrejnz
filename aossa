mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    local selfName = tostring(self)
    
    if not checkcaller() and getgenv().Weapon_Settings then
        if selfName == "DropItem" and method == "FireServer" then
            local weaponTable = args[1]
            if type(weaponTable) == "table" then
                local function patch(t)
                    if type(t) ~= "table" then return end
                    if getgenv().DropMod_Settings and getgenv().DropMod_Settings.Enabled then
                        local amt = math.floor(getgenv().DropMod_Settings.AmmoValue)
                        t.ammo = amt; t.currentAmmo = amt; t.Ammo = amt; t.maxAmmo = amt
                        if t.magSize then t.magSize = amt end
                    end
                    if getgenv().Weapon_Settings.UnlockFireModes and t.fireModes then
                        t.fireModes.full = true; t.fireModes.semi = true; t.fireModes.burst = true
                    end
                    if getgenv().Weapon_Settings.InstantVelocity then t.velocity = getgenv().Weapon_Settings.VelocityValue end
                    if getgenv().Weapon_Settings.RapidFire then t.fireRate = getgenv().Weapon_Settings.FireRateValue end
                    if getgenv().Weapon_Settings.NoRecoil then
                        t.vRecoil = Vector3.zero; t.cRecoil = Vector3.zero; t.aRecoil = Vector3.zero; t.shakeRecoil = 0
                        if t.blowBack then t.blowBack.amount = Vector3.zero end
                    end
                end
                if weaponTable.Module then patch(weaponTable.Module.Special) end
                patch(weaponTable.Special)
            end
            if getgenv().DropValueEnabled then args[4] = math.floor(getgenv().CustomDropAmount) end
            return oldNamecall(self, unpack(args))
        end

        if selfName == "HotWheeIs" and method == "FireServer" then
            if getgenv().Weapon_Settings.InstantVelocity then
                if type(args[8]) == "table" then args[8][5] = getgenv().Weapon_Settings.VelocityValue end
                args[12] = getgenv().Weapon_Settings.VelocityValue
            end
            if getgenv().Weapon_Settings.RapidFire then args[11] = getgenv().Weapon_Settings.FireRateValue end
            if getgenv().Weapon_Settings.NoRecoil then args[6] = 0 end
            if getgenv().Weapon_Settings.SpoofEnabled then 
                args[9] = getgenv().Weapon_Settings.CustomName; args[10] = getgenv().Weapon_Settings.CustomName 
            end
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)

