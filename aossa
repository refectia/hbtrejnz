local function getClosestPlayer()
    local cam = workspace.CurrentCamera
    if not cam then return nil end

    local center = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    local maxDist = FOVCircleSettings.CircleRadius or 75

    local closest = nil
    local closestDist = maxDist + 1

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            if head then
                local screenPos, visible = cam:WorldToViewportPoint(head.Position)
                
                local headScreen = Vector2.new(screenPos.X, screenPos.Y)
                local dist = (headScreen - center).Magnitude

                if dist <= maxDist and dist < closestDist then
                    closest = player
                    closestDist = dist
                end
            end
        end
    end

    return closest
end

local function hookbullet()
    for _, v in ipairs(getgc()) do
        if type(v) == "function" and getinfo(v).name == "new" and tostring(getfenv(v).script) == "BulletModule" then
            local old
            old = hookfunction(v, function(origin, velocity, acceleration, lifetime, caliber, unknown6, ignoreList, ...)
                local args = {origin, velocity, acceleration, lifetime, caliber, unknown6, ignoreList, ...}
                
                local ws = getgenv().Weapon_Settings
                if ws then
                    if ws.Wallbang then
                        local ignore = type(ignoreList) == "table" and ignoreList or {}
                        
                        for _, child in ipairs(workspace:GetChildren()) do
                            if child ~= workspace:FindFirstChild("Players") 
                               and child ~= workspace:FindFirstChild("Zombies") then
                                if not table.find(ignore, child) then
                                    table.insert(ignore, child)
                                end
                            end
                        end
                        
                        args[7] = ignore
                    end
                    
                    if ws.MagicBullet then
                        local entity = getClosestPlayer()
                        local head = entity and entity.Character and entity.Character:FindFirstChild("Head")
                        if head and origin then
                            local direction = (head.Position - origin).Unit
                            args[2] = direction * (velocity.Magnitude or 1000)
                        end
                    end
                end
                
                return old(unpack(args))
            end)
            break
        end
    end
end
